# Optional: MySQL (start Docker first: docker compose up -d)
# DATABASE_URL=mysql+pymysql://root:rootsecret@127.0.0.1:3306/indian_algo
#
# If DATABASE_URL is not set, the API uses SQLite at backend/instance/app.db

JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Angel One SmartAPI — Live Market Quote (https://apiconnect.angelone.in/.../market/v1/quote/) ---
# Required for GET /angel/live-quote (after you sign in to the app with /auth/login JWT).
#
# ANGEL_API_KEY        → header X-PrivateKey (your SmartAPI API key)
# ANGEL_JWT_TOKEN     → header Authorization: Bearer <jwt> (run: python scripts/angel_smartapi_login.py)
#
# For the login script only (not sent to quote API as body):
# ANGEL_CLIENT_ID=     # Angel login id
# ANGEL_PIN=           # 4-digit MPIN
# ANGEL_TOTP_SECRET=   # Authenticator secret (TOTP seed)
# ANGEL_EXCHANGE_TOKENS → see .env.example (SENSEX: BSE 99919000; SBIN: NSE 3045).
#
ANGEL_API_KEY=z6GCvlfB
ANGEL_CLIENT_ID=A1089464
ANGEL_PIN=4747
ANGEL_TOTP_SECRET=6L4SDGWQ47XSCPGCZOPA6BP7WE
ANGEL_JWT_TOKEN=eyJhbGciOiJIUzUxMiJ9..Q4LiQpnpqp_JskS0Aoa64Qx667NXUh5Z7LpMmxTdcqLEwWYA1yTZ89RCB9IdAExJV44iGVbcvzFaJKPyTXwqrw
# SENSEX = BSE index token 99919000 (not NSE). SBIN: {"NSE":["3045"]}
ANGEL_EXCHANGE_TOKENS={"BSE":["99919000"]}
# LTP | OHLC | FULL
ANGEL_QUOTE_MODE=LTP
#
# Headers required by Angel (defaults are safe for local dev; use real values if Angel rejects):
ANGEL_SOURCE_ID=WEB
ANGEL_CLIENT_LOCAL_IP=127.0.0.1
ANGEL_CLIENT_PUBLIC_IP=127.0.0.1
ANGEL_MAC_ADDRESS=00:00:00:00:00:00
ANGEL_USER_TYPE=USER
ANGEL_REQUEST_TIMEOUT_SEC=20
# Set true to include full Angel JSON in API response (debug only)
ANGEL_DEBUG=false
ANGEL_REFRESH_TOKEN=eyJhbGciOiJIUzUxMiJ9..G826_fsYsQqoI4daMtCHpO64u3N7OWbYGEfyrOsCpgIKOnqHfbsCgu_KSh5hE_ApXwzjKDQ5FXsxE9NxrKD_UA

# --- StocksRin (Strategy 3 backtest) ---
# App authorization header (static — same as browser login request)
STOCKSRIN_APP_AUTHORIZATION=
# Auto-login credentials (password must be base64, same as StocksRin web app sends)
STOCKSRIN_EMAIL=
STOCKSRIN_PASSWORD_B64=
STOCKSRIN_DEVICE_ID=device_strategy3
STOCKSRIN_DEVICE_TYPE=laptop
STOCKSRIN_EXCHANGE=NSE
STOCKSRIN_INDEX_EXCHANGE=BSE
STOCKSRIN_INDEX_SYMBOL=SENSEX
STOCKSRIN_RESOLUTION=10
STOCKSRIN_BASE_URL=https://apih.stocksrin.com
STOCKSRIN_REQUEST_TIMEOUT_SEC=30
# Run once: python scripts/import_stocksrin_session.py --login